compensation_analysis.sql

SELECT
  Attrition,
  ROUND(AVG(MonthlyIncome), 2) AS avg_monthly_income,
  MIN(MonthlyIncome) AS min_income,
  MAX(MonthlyIncome) AS max_income
FROM
  `employee-attrition-502903.Employee_Attrition.employee_attrition`
GROUP BY
  Attrition;

